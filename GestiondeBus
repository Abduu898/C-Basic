#include <stdio.h>
#include <stdlib.h>
#include<string.h>

typedef struct station{
int station_id;
char station[20];
char quartier[20];
int voyageurs;
struct station *next;
struct station *prev;
}station;

station *Creestation(int station_id,char nom[],char quartier[],int voyageurs){
station *nouveau=(station*)malloc(sizeof(station));
nouveau->station_id=station_id;
strcpy(nouveau->station,nom);
strcpy(nouveau->quartier,quartier);
nouveau->next=NULL;
nouveau->prev=NULL;
return nouveau;
}

void inserer_debut(station **tete, int station_id, char nom[], char quartier[], int voyageurs) {
    station *nouveau = Creestation(station_id, nom, quartier, voyageurs);
    if(!nouveau) return;

    if(*tete == NULL) {
        *tete = nouveau;
        return;
    }
    nouveau->next = *tete;
    (*tete)->prev = nouveau;
    *tete = nouveau;
}
void inserer_fin(station **tete, int station_id, char nom[],char quartier[],int voyageurs) {
station *nouveau = Creestation(station_id, nom, quartier, voyageurs);
if(!nouveau) return;
if(*tete == NULL) {
*tete = nouveau;
    return;}
station *temp = *tete;
while(temp->next != NULL) {
temp = temp->next;
    }
temp->next=nouveau;
nouveau->prev=temp;
}

void insere_apres(station **tete,int station_id,char nom[],char quartier[],int voyageurs,char pos[]){
