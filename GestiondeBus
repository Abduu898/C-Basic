}

station* supprimer_tete(station *tete){
if(tete==NULL){
    printf("Liste Vide \n");
    return NULL;
}
station *temp=tete;
tete = tete->next;
if(tete!=NULL){
    tete->prev=NULL;
}
free(temp);
return tete;
}
station* supprimer_fin(station *tete){
if(tete ==NULL){
    printf("Liste Vide \n");
    return NULL;
}
station *temp=tete;
if(temp->next==NULL){
    free(temp); return NULL;
}
while(temp->next!=NULL){
    temp=temp->next;
}
temp->prev->next=NULL;
free(temp);
return tete;
}
